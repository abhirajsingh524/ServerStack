# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (required)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/cognivault?retryWrites=true&w=majority

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_hex_string_here
REFRESH_TOKEN_SECRET=your_different_64_char_random_hex_string_here

# ── Encryption ────────────────────────────────────────────────────────────────
# Any string — SHA-256 hashed internally to produce a 32-byte AES-256-GCM key
ENCRYPTION_KEY=your_random_encryption_key_here

# ── Key Rotation (set ONLY during rotation window, then remove) ───────────────
# ENCRYPTION_KEY_PREV=your_old_encryption_key_here

# ── Redis Cache (optional — falls back to in-memory if not set) ───────────────
# REDIS_URL=redis://localhost:6379
# Production: REDIS_URL=redis://:password@your-redis-host:6379

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in dev)
# ALLOWED_ORIGINS=https://yourfrontend.com,https://app.yourfrontend.com
